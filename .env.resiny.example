# IA Resiny
# Copia estas variables a .env local y a las variables de entorno del despliegue.
# Groq será el proveedor principal y ChatGPT será respaldo/mejora.

GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# Solo para pruebas sin IA real. No activar en producción si quieres respuestas inteligentes.
RESINY_ALLOW_LOCAL_FALLBACK=false
