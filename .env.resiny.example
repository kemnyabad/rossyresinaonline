# IA Resiny
# Copia estas variables a .env local y a las variables de entorno del despliegue.
# Groq será el proveedor principal y ChatGPT será respaldo/mejora.

GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# Solo para pruebas sin IA real. No activar en producción si quieres respuestas inteligentes.
RESINY_ALLOW_LOCAL_FALLBACK=false

# Busqueda web controlada para dudas actuales de artesania/resina.
# Recomendado: brave. Alternativa: tavily.
RESINY_WEB_SEARCH_ENABLED=false
RESINY_WEB_SEARCH_PROVIDER=brave
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=

# Resiny Browser: lectura de paginas dentro de la misma IA.
# No usa buscador pago. Solo lee URLs de dominios aprobados o fuentes curadas.
RESINY_BROWSER_ENABLED=false
RESINY_BROWSER_ALLOWED_DOMAINS=
RESINY_BROWSER_SOURCE_URLS=
